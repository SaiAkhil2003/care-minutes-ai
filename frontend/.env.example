# Leave unset in local Vite dev to use the `/api` proxy.
# Set this in production when the frontend talks to a backend on a different origin.
# Examples:
# VITE_API_BASE_URL=https://api.example.com
# VITE_API_BASE_URL=https://your-render-backend.onrender.com
# VITE_API_BASE_URL=/api

# Used only for localhost preview/builds when VITE_API_BASE_URL is unset.
VITE_API_PORT=3000
