NODE_ENV=development
DATA_PROVIDER=file
PORT=3000
ENABLE_ALERT_SCHEDULER=false
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
# Set CORS_ALLOW_ALL=true only for temporary debugging. Do not enable it in production.
# CORS_ALLOW_ALL=false

# Optional file-store override. Leave unset in local dev to use database/dev-store.json.
# In production file mode, point this at persistent writable storage.
# LOCAL_DATA_FILE=/absolute/path/to/dev-store.json

# Recommended production mode, including on Render.
# Set DATA_PROVIDER=supabase and provide both values below.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-supabase-service-role-or-anon-key

# Optional AI/email integrations.
# Enable the scheduler on only one backend instance/process.
# ANTHROPIC_API_KEY=your-anthropic-key
# RESEND_API_KEY=your-resend-key
# RESEND_FROM_EMAIL=Care Minutes AI <alerts@example.com>
